docker-compose.override.yml

# ── Environment & Secrets ────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Logs ─────────────────────────────────────────
*.log
*.tmp

# ── Antigravity / Gemini ─────────────────────────
.gemini/

